# =============================================================================
# 1hrLearning - Open Knowledge Exchange Platform
# Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in the values

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=1hrlearning
DATABASE_URL=postgresql://postgres:your_secure_password@localhost:5432/1hrlearning

# Redis
REDIS_PASSWORD=your_redis_password
REDIS_URL=redis://:your_redis_password@localhost:6379

# JWT
JWT_SECRET=your_jwt_secret_min_32_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# NextAuth
NEXTAUTH_SECRET=your_nextauth_secret_min_32_chars
NEXTAUTH_URL=http://localhost:3000

# API
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# Email (SendGrid)
# Used for transactional emails (session confirmations, notifications)
# and opt-in skill-interest recommendations (respects adEmailOptOut flag)
SENDGRID_API_KEY=your_sendgrid_api_key
EMAIL_FROM=noreply@1hrlearning.com

# OAuth (optional)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Sentry (optional, for error monitoring)
SENTRY_DSN=your_sentry_dsn
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn

# Seed / Admin
# Used by db:seed to create the initial admin account
ADMIN_EMAIL=admin@1hrlearning.com
ADMIN_PASSWORD=Admin@1hrLearning2024!
ADMIN_USERNAME=admin

# App
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
NODE_ENV=development
PORT=4000
