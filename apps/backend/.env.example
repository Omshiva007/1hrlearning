# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/1hrlearning

# Redis
REDIS_URL=redis://:redis@localhost:6379

# JWT
JWT_SECRET=your_jwt_secret_at_least_32_characters_long
JWT_REFRESH_SECRET=your_jwt_refresh_secret_at_least_32_characters
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Server
PORT=4000
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000

# Email
SENDGRID_API_KEY=your_sendgrid_api_key
EMAIL_FROM=noreply@1hrlearning.com

# Sentry
SENTRY_DSN=

# App
APP_URL=http://localhost:3000

# Seed / Admin (used by db:seed to create the initial admin account)
ADMIN_EMAIL=admin@1hrlearning.com
ADMIN_PASSWORD=Admin@1hrLearning2024!
ADMIN_USERNAME=admin
