generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
  MODERATOR
  SUPPORT
}

enum MeetingProvider {
  ZOOM
  GOOGLE_MEET
  CUSTOM
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum SessionStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
  RATED
}

enum SessionApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum AvailabilityStatus {
  OPEN
  HELD
  BOOKED
}

enum FlagTargetType {
  PROFILE
  TESTIMONIAL
  SESSION
}

enum FlagStatus {
  OPEN
  RESOLVED
  DISMISSED
}

enum AdStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum AdPlacement {
  EMAIL
  TOPIC_PAGE
  DASHBOARD
  ALL
}

enum NotificationType {
  SESSION_REQUEST
  SESSION_CONFIRMED
  SESSION_CANCELLED
  SESSION_REMINDER
  SESSION_COMPLETED
  RATING_RECEIVED
  POINTS_EARNED
  SESSION_APPLIED
  SESSION_APPLICATION_ACCEPTED
  SESSION_APPLICATION_REJECTED
  SESSION_SKILL_MATCH
  INTEREST_RECEIVED
  INTEREST_APPROVED
  INTEREST_DECLINED
  BALANCE_LOW
  PUBLIC_SESSION_AVAILABLE
  POINTS_EXPIRY_WARNING
  TESTIMONIAL_RECEIVED
  ACCOUNT_SUSPENDED
  ACCOUNT_REINSTATED
  SYSTEM
}

enum PointTransactionType {
  EARNED_TEACHING
  SPENT_LEARNING
  BONUS
  PENALTY
  REFUND
  ADMIN_GRANT
  ADMIN_DEDUCT
  EXPIRY
}

// ─── Core Models ──────────────────────────────────────────────────────────────

model User {
  id                      String           @id @default(cuid())
  email                   String           @unique
  username                String           @unique
  displayName             String
  passwordHash            String
  bio                     String?
  avatarUrl               String?
  timezone                String           @default("UTC")
  role                    UserRole         @default(USER)
  isVerified              Boolean          @default(false)
  isActive                Boolean          @default(true)
  isSuspended             Boolean          @default(false)
  isBanned                Boolean          @default(false)
  suspendedAt             DateTime?
  suspendedReason         String?
  bannedAt                DateTime?
  bannedReason            String?
  isOnboardingComplete    Boolean          @default(false)
  pointsBalance           Int              @default(10)
  pointsLocked            Int              @default(0)
  defaultSessionDuration  Int              @default(60)
  totalSessionsTaught     Int              @default(0)
  totalSessionsLearned    Int              @default(0)
  weeklySessionsShared    Int              @default(0)
  weeklySessionsResetAt   DateTime         @default(now())
  averageRating           Float?
  ratingCount             Int              @default(0)
  isDiscoverable          Boolean          @default(true)
  reciprocalVisibility    Boolean          @default(false)
  adEmailOptOut           Boolean          @default(false)
  notificationPreferences Json?
  defaultMeetingProvider  MeetingProvider?
  defaultMeetingUrl       String?
  lastActiveAt            DateTime?
  lastPointActivityAt     DateTime         @default(now())
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  skills               UserSkill[]
  sessionsTeaching     Session[]            @relation("TeacherSessions")
  sessionsLearning     Session[]            @relation("LearnerSessions")
  notifications        Notification[]
  pointTransactions    PointTransaction[]
  ratingsGiven         Rating[]             @relation("RaterRatings")
  ratingsReceived      Rating[]             @relation("RatedUserRatings")
  verificationTokens   VerificationToken[]
  refreshTokens        RefreshToken[]
  sessionApplications  SessionApplication[]
  availability         Availability[]
  savedMeetingLinks    SavedMeetingLink[]
  testimonialsGiven    Testimonial[]        @relation("TestimonialAuthor")
  testimonialsReceived Testimonial[]        @relation("TestimonialRecipient")
  flagsReported        Flag[]               @relation("FlagReporter")
  flagsResolved        Flag[]               @relation("FlagResolver")
  auditLogs            AuditLog[]           @relation("AuditAdmin")

  @@index([email])
  @@index([username])
  @@index([role])
  @@index([isActive])
  @@index([isSuspended])
  @@index([createdAt])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model VerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  type      String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

// ─── Skills ───────────────────────────────────────────────────────────────────

model Skill {
  id           String   @id @default(cuid())
  name         String   @unique
  slug         String   @unique
  description  String?
  category     String
  subcategory  String?
  iconUrl      String?
  userCount    Int      @default(0)
  sessionCount Int      @default(0)
  isApproved   Boolean  @default(true)
  isFeatured   Boolean  @default(false)
  isDeprecated Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userSkills UserSkill[]
  sessions   Session[]

  @@index([slug])
  @@index([category])
  @@index([isApproved])
  @@index([isFeatured])
  @@index([userCount])
}

model UserSkill {
  id                String     @id @default(cuid())
  userId            String
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillId           String
  skill             Skill      @relation(fields: [skillId], references: [id], onDelete: Cascade)
  level             SkillLevel
  isTeaching        Boolean    @default(false)
  isLearning        Boolean    @default(false)
  description       String?
  yearsOfExperience Int?
  endorsementCount  Int        @default(0)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@unique([userId, skillId])
  @@index([userId])
  @@index([skillId])
  @@index([isTeaching])
  @@index([isLearning])
}

// ─── Sessions ─────────────────────────────────────────────────────────────────

model Session {
  id                  String        @id @default(cuid())
  teacherId           String
  teacher             User          @relation("TeacherSessions", fields: [teacherId], references: [id])
  learnerId           String?
  learner             User?         @relation("LearnerSessions", fields: [learnerId], references: [id])
  skillId             String
  skill               Skill         @relation(fields: [skillId], references: [id])
  status              SessionStatus @default(PENDING)
  isPublic            Boolean       @default(false)
  depthLevel          SkillLevel?
  agenda              String?
  applicationDeadline DateTime?
  maxLearners         Int           @default(1)
  scheduledAt         DateTime
  durationMinutes     Int           @default(60)
  meetingUrl          String?
  notes               String?
  pointsPerSession    Int           @default(5)
  pointsLocked        Boolean       @default(false)
  pointsLockedAt      DateTime?
  completedAt         DateTime?
  cancelledAt         DateTime?
  cancelReason        String?
  availabilityId      String?
  availability        Availability? @relation(fields: [availabilityId], references: [id])
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  ratings           Rating[]
  pointTransactions PointTransaction[]
  applications      SessionApplication[]
  testimonials      Testimonial[]
  flags             Flag[]

  @@index([teacherId])
  @@index([learnerId])
  @@index([skillId])
  @@index([status])
  @@index([isPublic])
  @@index([scheduledAt])
}

model SessionApplication {
  id          String                   @id @default(cuid())
  sessionId   String
  session     Session                  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  applicantId String
  applicant   User                     @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  status      SessionApplicationStatus @default(PENDING)
  message     String?
  depthLevel  SkillLevel?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  @@unique([sessionId, applicantId])
  @@index([sessionId])
  @@index([applicantId])
  @@index([status])
}

model Rating {
  id          String   @id @default(cuid())
  sessionId   String
  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  raterId     String
  rater       User     @relation("RaterRatings", fields: [raterId], references: [id])
  ratedUserId String
  ratedUser   User     @relation("RatedUserRatings", fields: [ratedUserId], references: [id])
  score       Int
  comment     String?
  createdAt   DateTime @default(now())

  @@unique([sessionId, raterId])
  @@index([sessionId])
  @@index([ratedUserId])
}

model Testimonial {
  id          String   @id @default(cuid())
  sessionId   String
  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  authorId    String
  author      User     @relation("TestimonialAuthor", fields: [authorId], references: [id])
  recipientId String
  recipient   User     @relation("TestimonialRecipient", fields: [recipientId], references: [id])
  content     String
  isApproved  Boolean  @default(true)
  isFlagged   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  flags Flag[]

  @@unique([sessionId, authorId])
  @@index([recipientId])
  @@index([isApproved])
  @@index([isFlagged])
}

// ─── Availability ─────────────────────────────────────────────────────────────

model Availability {
  id        String             @id @default(cuid())
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  startTime DateTime
  endTime   DateTime
  status    AvailabilityStatus @default(OPEN)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  sessions Session[]

  @@index([userId])
  @@index([status])
  @@index([startTime])
}

// ─── Meeting Links ────────────────────────────────────────────────────────────

model SavedMeetingLink {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String
  url       String
  provider  MeetingProvider @default(CUSTOM)
  createdAt DateTime        @default(now())

  @@index([userId])
}

// ─── Points ───────────────────────────────────────────────────────────────────

model PointTransaction {
  id           String               @id @default(cuid())
  userId       String
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         PointTransactionType
  amount       Int
  balanceAfter Int
  description  String
  sessionId    String?
  session      Session?             @relation(fields: [sessionId], references: [id])
  adminNote    String?
  createdAt    DateTime             @default(now())

  @@index([userId])
  @@index([sessionId])
  @@index([createdAt])
}

model PointConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Int
  description String
  updatedById String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  data      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

// ─── Moderation & Flags ───────────────────────────────────────────────────────

model Flag {
  id             String         @id @default(cuid())
  reporterId     String
  reporter       User           @relation("FlagReporter", fields: [reporterId], references: [id])
  targetType     FlagTargetType
  targetId       String
  reason         String
  status         FlagStatus     @default(OPEN)
  resolvedById   String?
  resolver       User?          @relation("FlagResolver", fields: [resolvedById], references: [id])
  resolutionNote String?
  resolvedAt     DateTime?
  createdAt      DateTime       @default(now())

  session     Session?     @relation(fields: [targetId], references: [id], map: "Flag_sessionId_fkey")
  testimonial Testimonial? @relation(fields: [targetId], references: [id], map: "Flag_testimonialId_fkey")

  @@index([targetType, targetId])
  @@index([status])
  @@index([reporterId])
}

// ─── Admin ────────────────────────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  adminId     String
  admin       User     @relation("AuditAdmin", fields: [adminId], references: [id])
  actionType  String
  targetType  String
  targetId    String
  beforeValue Json?
  afterValue  Json?
  reason      String?
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@index([adminId])
  @@index([targetType, targetId])
  @@index([createdAt])
}

model PlatformConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Ads ──────────────────────────────────────────────────────────────────────

model Ad {
  id             String      @id @default(cuid())
  advertiserName String
  title          String
  body           String
  targetUrl      String
  topicCategories String[]
  placement      AdPlacement @default(ALL)
  status         AdStatus    @default(ACTIVE)
  impressions    Int         @default(0)
  clicks         Int         @default(0)
  startDate      DateTime?
  endDate        DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([status])
  @@index([placement])
}
